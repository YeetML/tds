-- // ===== HELPER: Check if a remote response indicates success =====
local function CheckResOk(data)
    if data == true then return true end
    if type(data) == "table" and data.Success == true then return true end
    local success, IsModel = pcall(function()
        return data and data:IsA("Model")
    end)
    if success and IsModel then return true end
    if type(data) == "userdata" then return true end
    return false
end

-- // ===== GET EQUIPPED TOWERS =====
local function GetEquippedTowers()
    local towers = {}
    local StateReplicators = ReplicatedStorage:FindFirstChild("StateReplicators")
    if StateReplicators then
        for _, folder in ipairs(StateReplicators:GetChildren()) do
            if folder.Name == "PlayerReplicator" and folder:GetAttribute("UserId") == LocalPlayer.UserId then
                local equipped = folder:GetAttribute("EquippedTowers")
                if type(equipped) == "string" then
                    local CleanedJson = equipped:match("%[.*%]")
                    local success, TowerTable = pcall(function()
                        return HttpService:JSONDecode(CleanedJson)
                    end)
                    if success and type(TowerTable) == "table" then
                        for i = 1, 5 do
                            if TowerTable[i] and TowerTable[i] ~= "None" then
                                table.insert(towers, TowerTable[i])
                            end
                        end
                    end
                end
            end
        end
    end
    return towers
end

-- // ===== TRY PLACE TOWER AT POSITION =====
local function TryPlaceTower(towerName, position)
    local success, result = pcall(function()
        return RemoteFunc:InvokeServer("Troops", "Place", {
            Rotation = CFrame.new(),
            Position = position
        }, towerName)
    end)
    if success and CheckResOk(result) then
        return true, result
    end
    return false, result
end

-- // ===== GENERATE SCAN POSITIONS =====
local function GenerateScanPositions(center, radius, step)
    local positions = {}
    -- Scan in a spiral/grid pattern outward from center
    for x = -radius, radius, step do
        for z = -radius, radius, step do
            local pos = Vector3.new(
                center.X + x,
                center.Y,
                center.Z + z
            )
            -- Check distance from center
            local dist = (Vector3.new(pos.X, 0, pos.Z) - Vector3.new(center.X, 0, center.Z)).Magnitude
            if dist <= radius then
                table.insert(positions, pos)
            end
        end
    end
    -- Sort by distance from center (closest first)
    table.sort(positions, function(a, b)
        local da = (a - center).Magnitude
        local db = (b - center).Magnitude
        return da < db
    end)
    return positions
end

-- // ===== CHECK IF POSITION IS ALREADY OCCUPIED =====
local function IsPositionOccupied(position, checkRadius)
    checkRadius = checkRadius or 1.5
    local Towers = workspace:FindFirstChild("Towers")
    if not Towers then return false end
    for _, tower in ipairs(Towers:GetChildren()) do
        if tower:IsA("Model") then
            local primary = tower:FindFirstChild("TowerReplicator") or tower:FindFirstChildWhichIsA("BasePart")
            if primary then
                local tPos = primary:IsA("BasePart") and primary.Position or (primary:IsA("Folder") and primary.Parent and primary.Parent:FindFirstChildWhichIsA("BasePart") and primary.Parent:FindFirstChildWhichIsA("BasePart").Position)
                if tPos then
                    local dist = (Vector3.new(position.X, 0, position.Z) - Vector3.new(tPos.X, 0, tPos.Z)).Magnitude
                    if dist < checkRadius then
                        return true
                    end
                end
            end
        end
    end
    return false
end

-- // ===== MAIN AUTO PLACE FUNCTION =====
local function RunAutoPlace(clickPosition)
    if autoPlaceRunning then
        print("[AutoPlace] Already running!")
        return
    end
    if not IsInGame() then
        print("[AutoPlace] Must be in a game to place towers!")
        return
    end
    
    autoPlaceRunning = true
    autoPlaceStop = false
    autoPlacePlaced = 0
    autoPlaceCenter = clickPosition
    
    print("[AutoPlace] Starting auto place at: " .. tostring(clickPosition))
    print("[AutoPlace] Radius: " .. config.Radius .. ", Step: " .. config.Step)
    
    -- Get towers to place
    local towersToPlace = {}
    if config.UseAllEquipped then
        towersToPlace = GetEquippedTowers()
        if #towersToPlace == 0 then
            print("[AutoPlace] No equipped towers found!")
            autoPlaceRunning = false
            return
        end
    else
        towersToPlace = config.CustomTowers
        if #towersToPlace == 0 then
            print("[AutoPlace] No custom towers configured!")
            autoPlaceRunning = false
            return
        end
    end
    
    print("[AutoPlace] Towers to try: " .. table.concat(towersToPlace, ", "))
    
    -- Generate scan positions
    local basePositions = GenerateScanPositions(
        Vector3.new(clickPosition.X, 0, clickPosition.Z),
        config.Radius,
        config.Step
    )
    
    print("[AutoPlace] Generated " .. #basePositions .. " scan positions")
    
    -- For each position, try each tower at each Y variation
    for _, basePos in ipairs(basePositions) do
        if autoPlaceStop then
            print("[AutoPlace] Stopped by user")
            break
        end
        if autoPlacePlaced >= config.MaxPlacements then
            print("[AutoPlace] Reached max placements: " .. config.MaxPlacements)
            break
        end
        
        -- Check if position is already occupied
        if IsPositionOccupied(basePos) then
            continue
        end
        
        -- Try each Y variation
        for _, yOffset in ipairs(config.YVariations) do
            if autoPlaceStop then break end
            if autoPlacePlaced >= config.MaxPlacements then break end
            
            local tryPos = Vector3.new(basePos.X, yOffset, basePos.Z)
            
            -- Try each tower type at this position
            for _, towerName in ipairs(towersToPlace) do
                if autoPlaceStop then break end
                if autoPlacePlaced >= config.MaxPlacements then break end
                
                -- Check again if position got occupied
                if IsPositionOccupied(tryPos) then
                    break
                end
                
                local success, result = TryPlaceTower(towerName, tryPos)
                if success then
                    autoPlacePlaced = autoPlacePlaced + 1
                    print("[AutoPlace] Placed " .. towerName .. " at " .. tostring(tryPos) .. " (" .. autoPlacePlaced .. "/" .. config.MaxPlacements .. ")")
                    task.wait(0.3) -- Small delay between placements
                    break -- Move to next position after successful placement
                end
            end
        end
    end
    
    print("[AutoPlace] Finished! Placed " .. autoPlacePlaced .. " towers")
    autoPlaceRunning = false
    
    -- Update UI
    if autoPlaceUI and autoPlaceUI.status then
        autoPlaceUI.status.Text = "Status: Idle (Placed " .. autoPlacePlaced .. ")"
    end
end

-- // ===== CREATE VISUAL SPHERE =====
local function UpdateAutoPlaceSphere()
    if autoPlaceSphere then
        autoPlaceSphere:Destroy()
        autoPlaceSphere = nil
    end
    
    if config.Enabled then
        autoPlaceSphere = Instance.new("Part")
        autoPlaceSphere.Name = "AutoPlaceSphere"
        autoPlaceSphere.Shape = Enum.PartType.Ball
        autoPlaceSphere.Size = Vector3.new(1, 1, 1)
        autoPlaceSphere.Color = Color3.fromRGB(0, 200, 255)
        autoPlaceSphere.Transparency = 0.6
        autoPlaceSphere.Anchored = true
        autoPlaceSphere.CanCollide = false
        autoPlaceSphere.Material = Enum.Material.Neon
        autoPlaceSphere.Parent = workspace
        mouse.TargetFilter = autoPlaceSphere
    end
end

-- // ===== SAVE/LOAD CONFIG =====
local function SaveConfig()
    if writefile then
        local saveData = {
            Radius = config.Radius,
            Step = config.Step,
            UseAllEquipped = config.UseAllEquipped,
            MaxPlacements = config.MaxPlacements,
            CustomTowers = config.CustomTowers,
            YVariations = config.YVariations
        }
        writefile(SETTINGS_FILE, HttpService:JSONEncode(saveData))
    end
end

local function LoadConfig()
    if isfile and isfile(SETTINGS_FILE) then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile(SETTINGS_FILE))
        end)
        if success and type(data) == "table" then
            if data.Radius then config.Radius = data.Radius end
            if data.Step then config.Step = data.Step end
            if data.UseAllEquipped ~= nil then config.UseAllEquipped = data.UseAllEquipped end
            if data.MaxPlacements then config.MaxPlacements = data.MaxPlacements end
            if data.CustomTowers then config.CustomTowers = data.CustomTowers end
            if data.YVariations then config.YVariations = data.YVariations end
        end
    end
end

