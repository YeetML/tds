local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TeleportService = game:GetService("TeleportService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local RemoteFunction = ReplicatedStorage:WaitForChild("RemoteFunction")

local LOBBY_PLACE_ID = 3260590327
local MAX_LOSSES = 30

local activeStratThread = nil
local stratRunning = false
local teleported = false
local lossCount = 0

local function TeleportLobby()
    if teleported then
        return
    end

    teleported = true
    print("30 losses reached. Rejoining lobby...")

    local success, err = pcall(function()
        TeleportService:Teleport(LOBBY_PLACE_ID, LocalPlayer)
    end)

    if not success then
        warn("Teleport failed:", err)
        teleported = false
    end
end

local function StartStrategy()
    if stratRunning or teleported then
        return
    end

    stratRunning = true

    print("Starting strategy...")

    TDS:ResetIndex()
    TDS:Ready()

    TDS:Place("Pyromancer", -5.936307430267334, 0.9551397562026978, -31.831748962402344)
    TDS:SetTarget(1, "Farthest")

    for i = 1, 4 do
        TDS:Upgrade(1)
    end

    for i = 1, 10 do
        TDS:Place("Hunter", 2.679039716720581, 1.341203212738037, 21.30302619934082, true)
    end
        TDS:Place("Minigunner", 2.679039716720581, 1.341203212738037, 21.30302619934082, true)

    stratRunning = false
    print("Strategy finished.")
end

local function GetMatchStatus()
    local success, status = pcall(function()
        local uiRoot = PlayerGui:FindFirstChild("ReactGameNewRewards")
        if not uiRoot then
            return nil
        end

        local mainFrame = uiRoot:FindFirstChild("Frame")
        if not mainFrame or not mainFrame.Visible then
            return nil
        end

        local gameOver = mainFrame:FindFirstChild("gameOver")
        if not gameOver or not gameOver.Visible then
            return nil
        end

        local rewardsScreen = gameOver:FindFirstChild("RewardsScreen")
        if not rewardsScreen or not rewardsScreen.Visible then
            return nil
        end

        local topBanner = rewardsScreen:FindFirstChild("RewardBanner")
        local textLabel = topBanner and topBanner:FindFirstChild("textLabel")

        if not textLabel then
            return nil
        end

        local txt = textLabel.Text:upper()
        print("Banner text:", txt)

        if txt:find("LOST") then
            return "LOSS"
        end

        return nil
    end)

    if success then
        return status
    end

    return nil
end

local function FireVotingSkipUntilGone()
    print("Firing Voting Skip until reward screen disappears...")

    while GetMatchStatus() ~= nil and not teleported do
        local success, err = pcall(function()
            RemoteFunction:InvokeServer("Voting", "Skip")
        end)

        if success then
            print("Voting Skip fired")
        else
            warn("Voting Skip failed:", err)
        end

        task.wait(0.5)
    end

    print("Reward screen disappeared.")
end

task.spawn(function()
    activeStratThread = task.spawn(StartStrategy)

    while not teleported do
        task.wait(0.5)

        local currentStatus = GetMatchStatus()

        if currentStatus == "LOSS" then
            lossCount += 1
            print("Loss Count:", lossCount .. "/" .. MAX_LOSSES)

            print("Loss detected! Stopping old thread...")

            if activeStratThread and coroutine.status(activeStratThread) ~= "dead" then
                task.cancel(activeStratThread)
                activeStratThread = nil
            end

            stratRunning = false

            if lossCount >= MAX_LOSSES then
                TeleportLobby()
                break
            end

            FireVotingSkipUntilGone()

            task.wait(1.5)

            print("Starting new strategy match!")
            activeStratThread = task.spawn(StartStrategy)
        end
    end
end)
