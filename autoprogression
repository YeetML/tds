-- ===== APPLY STRATEGY SETTINGS (AutoSkip, AutoPremium, etc.) =====
local function ApplyStrategySettings(strategy)
    local MainGlobals = getgenv().Globals or _G.Globals
    local settings = {
        AutoSkip          = (strategy.autoSkip ~= nil) and strategy.autoSkip or false,
        AutoPremium       = (strategy.autoPremium ~= nil) and strategy.autoPremium or false,
        AutoRejoin        = (strategy.autoRejoin ~= nil) and strategy.autoRejoin or true,
    }
    print("[AutoProgression] Applying & LOCKING settings...")
    for key, value in pairs(settings) do
        getgenv()[key] = value
        _G.AutoProgSettings[key] = value
        if MainGlobals then MainGlobals[key] = value end
    end
    _G.AutoProgSettings.__locked = true
    print("[AutoProgression] ✅ SETTINGS LOCKED:")
    for key, value in pairs(settings) do
        print("   → " .. key .. " = " .. tostring(value))
    end
end

-- ===== BUY TOWER =====
local function BuyTower(towerName)
    print("Buying " .. towerName)
    local aliases = {
        ["EvolvedOperator"] = "Operator",
        ["EvolvedJuggernaut"] = "Juggernaut",
    }
    local function attemptPurchase(name)
        local success, result = pcall(function()
            return RemoteFunc:InvokeServer("Shop", "Purchase", "Tower", name)
        end)
        if success then
            print("Successfully bought " .. name)
            return true
        else
            print("Failed to buy " .. name .. ": " .. tostring(result))
            return false
        end
    end
    if attemptPurchase(towerName) then return true end
    local alternate = aliases[towerName]
    if alternate then
        print("Primary failed, trying alternate: " .. alternate)
        if attemptPurchase(alternate) then return true end
    end
    return false
end

-- ===== GET STAT =====
local function GetStat(name)
    local obj = LocalPlayer:FindFirstChild(name)
    if obj and obj.Value ~= nil then return tonumber(obj.Value) or 0 end
    local attr = LocalPlayer:GetAttribute(name)
    if attr ~= nil then return tonumber(attr) or 0 end
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    local stat = leaderstats and leaderstats:FindFirstChild(name)
    if stat and stat.Value ~= nil then return tonumber(stat.Value) or 0 end
    return 0
end

