            -- {"Tower", cost} -> Coins only
            requiredCoins = data[2]
        elseif #data == 3 then
            -- {"Tower", cost, "Gems"} -> Gems only (or "Coins")
            local cost = data[2]
            local currency = data[3]
            if currency == "Gems" then
                requiredGems = cost
            else
                requiredCoins = cost
            end
        elseif #data == 5 then
            -- {"Tower", cost1, "Coins", cost2, "Gems"} -> both
            local cost1 = data[2]
            local cur1 = data[3]
            local cost2 = data[4]
            local cur2 = data[5]

            if cur1 == "Coins" then requiredCoins = cost1
            elseif cur1 == "Gems" then requiredGems = cost1 end

            if cur2 == "Coins" then requiredCoins = cost2
            elseif cur2 == "Gems" then requiredGems = cost2 end
        elseif type(data[2]) == "table" then
            -- {"Tower", {Coins = x, Gems = y}} -> both (table style)
            local costTable = data[2]
            requiredCoins = costTable.Coins or 0
            requiredGems = costTable.Gems or 0
        else
            warn("[AutoProgression] Unknown format for tower: " .. name)
        end

        return name, requiredCoins, requiredGems
