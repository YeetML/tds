    local function CreateModeToggle(yOffset, label, settingKey)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 130, 0, 22)
        btn.Position = UDim2.new(0, 10, 0, yOffset)
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
        btn.Text = label .. ": OFF"
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextScaled = true
        btn.Font = Enum.Font.GothamBold
        btn.Parent = frame
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
        return btn
    end

    local easyBtn = CreateModeToggle(208, "Easy", "ForceEasy")
    local frostBtn = CreateModeToggle(234, "Frost", "ForceFrost")
    local hcScoutBtn = CreateModeToggle(260, "HC Scout", "ForceHardcoreScout")
    local hcMinigunnerBtn = CreateModeToggle(286, "HC Minigunner", "ForceHardcoreMinigunner")
    local hcOperatorBtn = CreateModeToggle(312, "HC Operator", "ForceHardcoreOperator")
    local hcJuggernautBtn = CreateModeToggle(338, "HC Juggernaut", "ForceHardcoreJuggernaut")

    -- Helper to update a mode button
    local function updateModeButton(btn, settingKey)
        if _G.AutoProgSettings[settingKey] then
            btn.Text = btn.Text:gsub(": OFF", ": ON")
            btn.BackgroundColor3 = Color3.fromRGB(0, 170, 80)
        else
            btn.Text = btn.Text:gsub(": ON", ": OFF")
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
        end
    end

    -- Save settings
    local function saveSettings()
        if writefile then
            local saveData = {
                AutoProgressionEnabled = _G.AutoProgSettings.AutoProgressionEnabled,
                ForceEasy = _G.AutoProgSettings.ForceEasy,
                ForceFrost = _G.AutoProgSettings.ForceFrost,
                ForceHardcoreScout = _G.AutoProgSettings.ForceHardcoreScout,
                ForceHardcoreMinigunner = _G.AutoProgSettings.ForceHardcoreMinigunner,
                ForceHardcoreOperator = _G.AutoProgSettings.ForceHardcoreOperator,
                ForceHardcoreJuggernaut = _G.AutoProgSettings.ForceHardcoreJuggernaut,
            }
            writefile(SETTINGS_FILE, HttpService:JSONEncode(saveData))
        end
    end

    -- Update main UI (considers both main toggle and force toggles)
    local function updateMainUI()
        local anyForceOn = _G.AutoProgSettings.ForceEasy or
                           _G.AutoProgSettings.ForceFrost or
                           _G.AutoProgSettings.ForceHardcoreScout or
                           _G.AutoProgSettings.ForceHardcoreMinigunner or
                           _G.AutoProgSettings.ForceHardcoreOperator or
                           _G.AutoProgSettings.ForceHardcoreJuggernaut

        local isRunning = AutoProgressionEnabled or anyForceOn

        if isRunning then
            toggle.Text = "ON"
            toggle.BackgroundColor3 = Color3.fromRGB(0, 170, 80)
            if anyForceOn then
                title.Text = "Auto Progression (Forced)"
                statusDisplay.Text = "Status: Forcing Mode"
            else
                title.Text = "Auto Progression Running"
                statusDisplay.Text = "Status: Running..."
            end
        else
            toggle.Text = "OFF"
            toggle.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
            title.Text = "Auto Progression OFF"
            statusDisplay.Text = "Status: Stopped"
        end
    end

    -- Force toggle handler (mutual exclusivity + auto‑start)
    local function toggleMode(settingKey, btn)
        -- Turn off all other force toggles
        local forceKeys = {
            "ForceEasy", "ForceFrost", "ForceHardcoreScout",
            "ForceHardcoreMinigunner", "ForceHardcoreOperator", "ForceHardcoreJuggernaut"
        }
        for _, key in ipairs(forceKeys) do
            if key ~= settingKey then
                _G.AutoProgSettings[key] = false
            end
        end

        -- Toggle the clicked one
        _G.AutoProgSettings[settingKey] = not _G.AutoProgSettings[settingKey]

        -- Update all mode buttons
        updateModeButton(easyBtn, "ForceEasy")
        updateModeButton(frostBtn, "ForceFrost")
        updateModeButton(hcScoutBtn, "ForceHardcoreScout")
        updateModeButton(hcMinigunnerBtn, "ForceHardcoreMinigunner")
        updateModeButton(hcOperatorBtn, "ForceHardcoreOperator")
        updateModeButton(hcJuggernautBtn, "ForceHardcoreJuggernaut")

        -- If a force toggle is turned ON, start the script
        if _G.AutoProgSettings[settingKey] then
            AutoProgressionEnabled = true
            _G.AutoProgSettings.AutoProgressionEnabled = true
            updateMainUI()
            saveSettings()
            task.spawn(RunAutoProgression)
        else
            -- If all force toggles are off, we might still have main toggle on
            -- Update UI accordingly
            updateMainUI()
            saveSettings()
        end
    end

    -- Main toggle click
    toggle.MouseButton1Click:Connect(function()
        AutoProgressionEnabled = not AutoProgressionEnabled
        _G.AutoProgSettings.AutoProgressionEnabled = AutoProgressionEnabled

        if not AutoProgressionEnabled then
            -- Turn off all force toggles
            local forceKeys = {
                "ForceEasy", "ForceFrost", "ForceHardcoreScout",
                "ForceHardcoreMinigunner", "ForceHardcoreOperator", "ForceHardcoreJuggernaut"
            }
            for _, key in ipairs(forceKeys) do
                _G.AutoProgSettings[key] = false
            end
            -- Update mode buttons
            updateModeButton(easyBtn, "ForceEasy")
            updateModeButton(frostBtn, "ForceFrost")
            updateModeButton(hcScoutBtn, "ForceHardcoreScout")
            updateModeButton(hcMinigunnerBtn, "ForceHardcoreMinigunner")
            updateModeButton(hcOperatorBtn, "ForceHardcoreOperator")
            updateModeButton(hcJuggernautBtn, "ForceHardcoreJuggernaut")
        end

        updateMainUI()
        saveSettings()

        if AutoProgressionEnabled then
            task.spawn(RunAutoProgression)
        else
            _G.AutoProgSettings.__locked = false
        end
    end)

    -- Mode button clicks
    easyBtn.MouseButton1Click:Connect(function() toggleMode("ForceEasy", easyBtn) end)
    frostBtn.MouseButton1Click:Connect(function() toggleMode("ForceFrost", frostBtn) end)
    hcScoutBtn.MouseButton1Click:Connect(function() toggleMode("ForceHardcoreScout", hcScoutBtn) end)
    hcMinigunnerBtn.MouseButton1Click:Connect(function() toggleMode("ForceHardcoreMinigunner", hcMinigunnerBtn) end)
    hcOperatorBtn.MouseButton1Click:Connect(function() toggleMode("ForceHardcoreOperator", hcOperatorBtn) end)
    hcJuggernautBtn.MouseButton1Click:Connect(function() toggleMode("ForceHardcoreJuggernaut", hcJuggernautBtn) end)

    -- Load saved state
    if isfile and isfile(SETTINGS_FILE) then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile(SETTINGS_FILE))
        end)
        if success and type(data) == "table" then
            for k, v in pairs(data) do
                _G.AutoProgSettings[k] = v
            end
        end
    end

    -- Apply loaded state: if any force toggle is on, start the script
    AutoProgressionEnabled = _G.AutoProgSettings.AutoProgressionEnabled or false
    local anyForceOn = _G.AutoProgSettings.ForceEasy or
                       _G.AutoProgSettings.ForceFrost or
                       _G.AutoProgSettings.ForceHardcoreScout or
                       _G.AutoProgSettings.ForceHardcoreMinigunner or
                       _G.AutoProgSettings.ForceHardcoreOperator or
                       _G.AutoProgSettings.ForceHardcoreJuggernaut
    if anyForceOn then
        AutoProgressionEnabled = true
        _G.AutoProgSettings.AutoProgressionEnabled = true
    end

    updateMainUI()
    updateModeButton(easyBtn, "ForceEasy")
    updateModeButton(frostBtn, "ForceFrost")
    updateModeButton(hcScoutBtn, "ForceHardcoreScout")
    updateModeButton(hcMinigunnerBtn, "ForceHardcoreMinigunner")
    updateModeButton(hcOperatorBtn, "ForceHardcoreOperator")
    updateModeButton(hcJuggernautBtn, "ForceHardcoreJuggernaut")

    if AutoProgressionEnabled then
        task.spawn(RunAutoProgression)
    end

    -- Dragging
    local dragging = false
    local dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
                                       startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)

    -- Update stats every second
    task.spawn(function()
        while task.wait(1) do
            local level = GetStat("Level")
            local coins = GetStat("Coins")
            local gems = GetStat("Gems")
            levelDisplay.Text = "Level: " .. tostring(level)
            coinsDisplay.Text = "Coins: " .. tostring(coins)
            gemsDisplay.Text = "Gems: " .. tostring(gems)
        end
    end)

    return {
        title = title,
        status = statusDisplay,
        toggle = toggle,
        levelDisplay = levelDisplay,
        coinsDisplay = coinsDisplay,
        gemsDisplay = gemsDisplay,
        easyBtn = easyBtn,
        frostBtn = frostBtn,
        hcScoutBtn = hcScoutBtn,
        hcMinigunnerBtn = hcMinigunnerBtn,
        hcOperatorBtn = hcOperatorBtn,
        hcJuggernautBtn = hcJuggernautBtn,
    }
end

