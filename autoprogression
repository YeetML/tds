-- Helper to get keys from a table
local function GetKeys(t)
    local keys = {}
    for k in pairs(t) do
        keys[#keys + 1] = k
    end
    return keys
end

-- // ===== GET REMAINING VETO COUNT =====
local function GetRemainingVetos()
    local PlayerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not PlayerGui then return nil end
    
    local ReactLobbyHud = PlayerGui:FindFirstChild("ReactLobbyHud")
    if not ReactLobbyHud then return nil end
    
    local Frame = ReactLobbyHud:FindFirstChild("Frame")
    if not Frame then return nil end
    
    local Matchmaking = Frame:FindFirstChild("matchmaking")
    if not Matchmaking then return nil end
    
    local Buttons = Matchmaking:FindFirstChild("buttons")
    if not Buttons then return nil end
    
    local VetoButton = Buttons:FindFirstChild("veto")
    if not VetoButton then return nil end
    
    for _, child in pairs(VetoButton:GetChildren()) do
        if child:IsA("TextLabel") then
            local text = child.Text
            local remaining = tonumber(text:match("(%d+)/"))
            if remaining then
                return remaining
            end
        end
    end
    return nil
end

-- // ===== VETO MAP =====
local function VetoMap()
    print("[AutoProgression] Attempting to veto...")
    local remaining = GetRemainingVetos()
    if remaining and remaining <= 0 then
        print("[AutoProgression] No vetos left, cannot veto.")
        return false
    end
    
    pcall(function()
        RemoteEvent:FireServer("LobbyVoting", "Veto")
        print("[AutoProgression] Veto fired. Remaining vetos: " .. tostring(remaining))
    end)
    task.wait(1)
    return true
end

-- // ===== RUN EASY STRATEGY (unchanged) =====
local function RunYeetEasy()
    if runningEasy then return end
    runningEasy = true
    rawset(getgenv(), "TimeScaleEnabled", false)
    
    if not IsInLobby() then
        local vetoAttempts = 0
        local maxVetos = GetRemainingVetos() or 3
        
        while vetoAttempts < maxVetos do
            local availableMaps = GetAvailableMaps()
            local mapKeys = GetKeys(availableMaps)
            print("[AutoProgression] Available maps: " .. (#mapKeys > 0 and table.concat(mapKeys, ", ") or "none"))
            
            local availableStrategies = {}
            for _, strategy in ipairs(EasyStrategies) do
                if availableMaps[strategy.mapName] then
                    table.insert(availableStrategies, strategy)
                    print("[AutoProgression] Found available map: " .. strategy.mapName)
                end
            end
            
            if #availableStrategies > 0 then
                local chosenStrategy = availableStrategies[math.random(1, #availableStrategies)]
                -- 👇 NEW: Apply per‑map settings
                ApplyStrategySettings(chosenStrategy)
                print("[AutoProgression] Selected: " .. chosenStrategy.name .. " on " .. chosenStrategy.mapName)
                print("[AutoProgression] Loading strategy from: " .. chosenStrategy.url)
                loadstring(game:HttpGet(chosenStrategy.url))()
                runningEasy = false
                return
            else
                print("[AutoProgression] No suitable map. Veto attempt " .. (vetoAttempts+1) .. "/" .. maxVetos)
                local vetoSuccess = VetoMap()
                if not vetoSuccess then
                    print("[AutoProgression] Veto failed (no vetoes left?). Breaking.")
                    break
                end
                vetoAttempts = vetoAttempts + 1
            end
        end
        
        print("[AutoProgression] No easy maps available after using all vetoes. Teleporting to lobby...")
        runningEasy = false
        SmartTeleportToLobby()
        return
    else
        local chosenStrategy = EasyStrategies[math.random(1, #EasyStrategies)]
        -- 👇 NEW: Apply per‑map settings
        ApplyStrategySettings(chosenStrategy)
        print("[AutoProgression] In lobby, randomly selected: " .. chosenStrategy.name .. " strategy")
        print("[AutoProgression] Loading strategy from: " .. chosenStrategy.url)
        loadstring(game:HttpGet(chosenStrategy.url))()
    end
    
    runningEasy = false
end

