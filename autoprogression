                {"Gatling Gun", 35000, "Coins"},
                {"Trapper", 3000, "Coins"},
                {"Hacker", 5500, "Gems"},
                {"Rocketeer", 2500, "Coins"},
            })
            if result == "OK" then
                RunFrostStrategy()
            elseif result == "Coins" then
                print("[AutoProgression] Not enough Coins for Frost – farming Easy.")
                RunYeetEasy()
            elseif result == "Gems" then
                print("[AutoProgression] Not enough Gems for Frost – farming Hardcore Scout.")
                loadstring(game:HttpGet("https://raw.githubusercontent.com/YeetML/tds/refs/heads/main/hardcorescout"))()
