local function RunAutoProgression()
    if AutoProgressionRunning then return end
    AutoProgressionRunning = true

    task.wait(3)

    local level = GetStat("Level")
    local coins = GetStat("Coins")

    local state = ReplicatedStorage:FindFirstChild("State")
    local difficulty = state and state:FindFirstChild("Difficulty")
    local currentDifficulty = difficulty and difficulty.Value or nil

    if currentDifficulty == "Frost" and level < 176 then
        print("[AutoProgression] In Frost match but level < 176 – teleporting to lobby.")
        AutoProgressionRunning = false
        SmartTeleportToLobby()
        return
    end

    if level >= 176 then
        local haveGatling = OwnsTower("Gatling Gun")
        local haveTrapper = OwnsTower("Trapper")
        local haveHacker = OwnsTower("Hacker")

        if haveGatling and haveTrapper and haveHacker then
            RunFrostStrategy()
            AutoProgressionRunning = false
            return
        end

        local maxAttempts = 10
        for attempt = 1, maxAttempts do
            local result = AutoBuyTowers({
                {"Gatling Gun", 35000, "Coins"},
                {"Trapper", 3000, "Coins"},
                {"Hacker", 5500, "Gems"},
            })

            if result == "OK" then
                RunFrostStrategy()
                AutoProgressionRunning = false
                return
            elseif result == "Coins" then
                if currentDifficulty == "Frost" then
                    print("[AutoProgression] In Frost match but need Coins – teleporting to lobby to farm.")
                    AutoProgressionRunning = false
                    SmartTeleportToLobby()
                    return
                else
                    RunYeetEasy()
