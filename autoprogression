-- ===== OWN TOWER CHECK =====
local function OwnsTower(towerName)
    local maxAttempts = 15
    for attempt = 1, maxAttempts do
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            local inventoryView = playerGui:FindFirstChild("ReactUniversalInventoryView")
            if inventoryView then
                local holder = inventoryView:FindFirstChild("Holder")
                if holder then
                    local windowFrame = holder:FindFirstChild("windowFrame")
                    if windowFrame then
                        local towersFrame = windowFrame:FindFirstChild("towersInventoryFrame")
                        if towersFrame then
                            local towerContainer = towersFrame:FindFirstChild("towerContainer")
                            if towerContainer then
                                task.wait(2)
                                for _, child in ipairs(towerContainer:GetChildren()) do
                                    if string.find(child.Name, "scrolling") then
                                        local towerFrame = child:FindFirstChild(towerName)
                                        if towerFrame then
                                            local main = towerFrame:FindFirstChild("main")
                                            if main then
                                                local topThing = main:FindFirstChild("topThing")
                                                if topThing then
                                                    return not topThing.Visible
                                                end
                                            end
                                        end
                                    end
                                end
                                return false
                            end
                        end
                    end
                end
            end
        end
        task.wait(0.5)
    end
    warn("[AutoProgression] Timeout waiting for inventory UI – assuming tower NOT owned.")
    return false
end

-- ===== AUTO BUY TOWERS =====
local function AutoBuyTowers(towerList)
    print("[AutoProgression] Checking towers to buy...")
    local function parseTowerData(data)
        local name = data[1]
        local requiredCoins = 0
        local requiredGems = 0
        if #data == 2 then
            requiredCoins = data[2]
        elseif #data == 3 then
            local cost = data[2]
            local currency = data[3]
            if currency == "Gems" then requiredGems = cost else requiredCoins = cost end
        elseif #data == 5 then
            local cost1 = data[2]; local cur1 = data[3]
            local cost2 = data[4]; local cur2 = data[5]
            if cur1 == "Coins" then requiredCoins = cost1 elseif cur1 == "Gems" then requiredGems = cost1 end
            if cur2 == "Coins" then requiredCoins = cost2 elseif cur2 == "Gems" then requiredGems = cost2 end
        elseif type(data[2]) == "table" then
            local costTable = data[2]
            requiredCoins = costTable.Coins or 0
            requiredGems = costTable.Gems or 0
        else
            warn("[AutoProgression] Unknown format for tower: " .. name)
        end
        return name, requiredCoins, requiredGems
    end
    for _, towerData in ipairs(towerList) do
        local towerName, needCoins, needGems = parseTowerData(towerData)
        local hasCoins = GetStat("Coins") >= needCoins
        local hasGems  = GetStat("Gems")  >= needGems
        if not OwnsTower(towerName) then
            if not hasCoins then
                print("[AutoProgression] Not enough Coins for " .. towerName)
                return "Coins"
            end
            if not hasGems then
                print("[AutoProgression] Not enough Gems for " .. towerName)
                return "Gems"
            end
            local msg = ("[AutoProgression] Buying %s"):format(towerName)
            if needCoins > 0 and needGems > 0 then
                msg = msg .. (" (need %d Coins + %d Gems)"):format(needCoins, needGems)
            elseif needCoins > 0 then
                msg = msg .. (" (need %d Coins)"):format(needCoins)
            elseif needGems > 0 then
                msg = msg .. (" (need %d Gems)"):format(needGems)
            end
            print(msg)
            BuyTower(towerName)
            task.wait(1)
        else
            print("[AutoProgression] Already own " .. towerName)
        end
    end
    return "OK"
end

