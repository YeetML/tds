-- // ===== CHECK IF TOWER IS OWNED =====
local function OwnsTower(towerName)
    local success, result = pcall(function()
        return RemoteFunc:InvokeServer("Shop", "GetOwned", "Tower", towerName)
    end)
    if success and result == true then
        return true
    end
    -- Fallback: check inventory
    local inv = LocalPlayer:FindFirstChild("Inventory")
    if inv then
        local towers = inv:FindFirstChild("Towers")
        if towers then
            return towers:FindFirstChild(towerName) ~= nil
        end
    end
    return false
end

-- // ===== AUTO BUY TOWERS =====
local function AutoBuyTowers(towerList)
    print("[AutoProgression] Checking towers to buy...")
    for _, towerData in ipairs(towerList) do
        local towerName = towerData[1]
        local towerCost = towerData[2]
        local coins = GetStat("Coins")
        
        if not OwnsTower(towerName) then
            if coins >= towerCost then
                print("[AutoProgression] Buying " .. towerName .. " for " .. tostring(towerCost) .. " coins")
                BuyTower(towerName)
                task.wait(1)
            else
                print("[AutoProgression] Not enough coins for " .. towerName .. " (need " .. tostring(towerCost) .. ", have " .. tostring(coins) .. ")")
            end
        else
            print("[AutoProgression] Already own " .. towerName)
        end
    end
end

