local function ApplyStrategySettings(strategy)
    -- Compute desired values
    local settings = {
        AutoSkip = (strategy.autoSkip ~= nil) and strategy.autoSkip or true,
        AutoPremium = (strategy.autoPremium ~= nil) and strategy.autoPremium or false,
        AutoRejoin = (strategy.autoRejoin ~= nil) and strategy.autoRejoin or true,
        TimeScaleEnabled = (strategy.timeScaleEnabled ~= nil) and strategy.timeScaleEnabled or false,
        TimeScaleValue = (strategy.timeScaleValue ~= nil) and strategy.timeScaleValue or 1,
    }

    -- Write to global environment (immediate use)
    for key, value in pairs(settings) do
        getgenv()[key] = value
    end

    -- Write to shared table and lock it
    for key, value in pairs(settings) do
        _G.AutoProgSettings[key] = value
    end
    _G.AutoProgSettings.__locked = true   -- tell YeetML to stop overwriting

    print("[AutoProgression] Settings applied (locked):",
        "AutoSkip=" .. tostring(getgenv().AutoSkip),
        "AutoPremium=" .. tostring(getgenv().AutoPremium),
        "TimeScale=" .. tostring(getgenv().TimeScaleEnabled) .. "(" .. tostring(getgenv().TimeScaleValue) .. ")"
    )
end

-- // ===== BUY TOWER FUNCTION =====
local function BuyTower(towerName)
    print("Buying " .. towerName)
    local success, result = pcall(function()
        return RemoteFunc:InvokeServer("Shop", "Purchase", "Tower", towerName)
    end)
    if success then
        print("Successfully bought " .. towerName)
    else
        print("Failed to buy " .. towerName .. ": " .. tostring(result))
    end
    return success
end

-- // ===== GET STAT FUNCTION =====
local function GetStat(name)
    local obj = LocalPlayer:FindFirstChild(name)
    if obj and obj.Value ~= nil then
        return tonumber(obj.Value) or 0
    end
    local attr = LocalPlayer:GetAttribute(name)
    if attr ~= nil then
        return tonumber(attr) or 0
    end
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    local stat = leaderstats and leaderstats:FindFirstChild(name)
    if stat and stat.Value ~= nil then
        return tonumber(stat.Value) or 0
    end
    return 0
end

