local function GetKeys(t)
    local keys = {}
    for k in pairs(t) do keys[#keys+1] = k end
    return keys
end

local function GetVetoInfo()
    local PlayerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not PlayerGui then return nil end
    local Intermission = PlayerGui:FindFirstChild("ReactGameIntermission")
    if not Intermission then return nil end
    local Frame = Intermission:FindFirstChild("Frame")
    if not Frame then return nil end
    local Buttons = Frame:FindFirstChild("buttons")
    if not Buttons then return nil end
    local VetoButton = Buttons:FindFirstChild("veto")
    if not VetoButton then return nil end
    local valueLabel = VetoButton:FindFirstChild("value")
    if valueLabel and valueLabel:IsA("TextLabel") then
        local text = valueLabel.Text  -- "Veto (0/1)" or "Veto (1/1)"
        local used, total = text:match("Veto %((%d+)/(%d+)%)")
        if used and total then
            return { used = tonumber(used), total = tonumber(total) }
        end
    end
    return nil
end

local function GetRemainingVetos()
    local info = GetVetoInfo()
    if info then
        return info.total - info.used
    end
    return nil
end

local function VetoMap()
    print("[AutoProgression] Attempting to veto...")
    pcall(function()
        RemoteEvent:FireServer("LobbyVoting", "Veto")
        print("[AutoProgression] Veto fired.")
    end)
