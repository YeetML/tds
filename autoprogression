local function OwnsTower(towerName)
    local maxAttempts = 15   -- ~7.5 seconds to find the UI
    for attempt = 1, maxAttempts do
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            local inventoryView = playerGui:FindFirstChild("ReactUniversalInventoryView")
            if inventoryView then
                local holder = inventoryView:FindFirstChild("Holder")
                if holder then
                    local windowFrame = holder:FindFirstChild("windowFrame")
                    if windowFrame then
                        local towersFrame = windowFrame:FindFirstChild("towersInventoryFrame")
                        if towersFrame then
                            local towerContainer = towersFrame:FindFirstChild("towerContainer")
                            if towerContainer then
                                -- UI is now loaded – wait 2 seconds for it to stabilise
                                task.wait(2)
                                
                                -- Now do a fresh check
                                for _, child in ipairs(towerContainer:GetChildren()) do
                                    if string.find(child.Name, "scrolling") then
                                        local towerFrame = child:FindFirstChild(towerName)
                                        if towerFrame then
                                            local main = towerFrame:FindFirstChild("main")
                                            if main then
                                                local topThing = main:FindFirstChild("topThing")
                                                if topThing then
                                                    -- Return ownership based on topThing visibility
                                                    local owned = not topThing.Visible
                                                    return owned
                                                end
                                            end
                                        end
                                    end
                                end
                                -- Tower not found => not owned
                                return false
                            end
                        end
                    end
                end
            end
        end
        task.wait(0.5)
    end
    warn("[AutoProgression] Timeout waiting for inventory UI – assuming tower NOT owned.")
    return false
end
