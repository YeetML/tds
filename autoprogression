    for _, g in ipairs(workspace:GetDescendants()) do
        if g:IsA("SurfaceGui") and g.Name == "MapDisplay" then
            local t = g:FindFirstChild("Title")
            if t and t.Text and t.Text ~= "" then
                maps[t.Text] = true
            end
        end
    end
    return maps
end

