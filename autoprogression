    levelDisplay.Position = UDim2.new(0, 0, 0, 60)
    levelDisplay.BackgroundTransparency = 1
    levelDisplay.Text = "Level: " .. tostring(GetStat("Level"))
    levelDisplay.TextColor3 = Color3.fromRGB(255, 255, 255)
    levelDisplay.TextScaled = true
    levelDisplay.Font = Enum.Font.GothamBold
    levelDisplay.TextXAlignment = Enum.TextXAlignment.Center
    levelDisplay.Parent = frame
    
    local statusDisplay = Instance.new("TextLabel")
    statusDisplay.Size = UDim2.new(1, 0, 0, 25)
    statusDisplay.Position = UDim2.new(0, 0, 0, 88)
    statusDisplay.BackgroundTransparency = 1
    statusDisplay.Text = "Status: Idle"
    statusDisplay.TextColor3 = Color3.fromRGB(200, 200, 200)
    statusDisplay.TextScaled = true
    statusDisplay.Font = Enum.Font.GothamBold
    statusDisplay.TextXAlignment = Enum.TextXAlignment.Center
    statusDisplay.Parent = frame

    local debugDisplay = Instance.new("TextLabel")
    debugDisplay.Size = UDim2.new(1, -20, 0, 40)
    debugDisplay.Position = UDim2.new(0, 10, 0, 112)
    debugDisplay.BackgroundTransparency = 1
    debugDisplay.Text = "Frost Maps: None"
    debugDisplay.TextColor3 = Color3.fromRGB(255, 255, 0)
    debugDisplay.TextScaled = false
    debugDisplay.TextSize = 14
    debugDisplay.Font = Enum.Font.Code
    debugDisplay.TextWrapped = true
    debugDisplay.TextXAlignment = Enum.TextXAlignment.Left
    debugDisplay.TextYAlignment = Enum.TextYAlignment.Top
    debugDisplay.Parent = frame
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 90, 0, 30)
    toggle.Position = UDim2.new(0.5, -45, 1, -45)
    toggle.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    toggle.Text = "OFF"
    toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggle.TextScaled = true
    toggle.Font = Enum.Font.GothamBold
    toggle.Parent = frame
    
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 10)
    
    local savedState = false
    if isfile and isfile(SETTINGS_FILE) then
        local success, data = pcall(function()
            return HttpService:JSONDecode(readfile(SETTINGS_FILE))
        end)
        if success and type(data) == "table" and data.AutoProgression ~= nil then
            savedState = data.AutoProgression
        end
    end
    
    toggle.MouseButton1Click:Connect(function()
        AutoProgressionEnabled = not AutoProgressionEnabled
        
        if writefile then
            local saveData = { AutoProgression = AutoProgressionEnabled }
            writefile(SETTINGS_FILE, HttpService:JSONEncode(saveData))
        end
        
        if AutoProgressionEnabled then
            toggle.Text = "ON"
            toggle.BackgroundColor3 = Color3.fromRGB(0, 170, 80)
            title.Text = "Auto Progression Running"
            statusDisplay.Text = "Status: Running..."
            task.spawn(RunAutoProgression)
        else
            toggle.Text = "OFF"
            toggle.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
            title.Text = "Auto Progression OFF"
            statusDisplay.Text = "Status: Stopped"
            _G.AutoProgSettings.__locked = false
        end
    end)
    
    if savedState then
        AutoProgressionEnabled = true
        toggle.Text = "ON"
        toggle.BackgroundColor3 = Color3.fromRGB(0, 170, 80)
        title.Text = "Auto Progression Running"
        statusDisplay.Text = "Status: Running..."
        task.spawn(RunAutoProgression)
    end
    
    -- Dragging
    local dragging = false
    local dragInput
    local dragStart
    local startPos
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    task.spawn(function()
        while task.wait(1) do
            local level = GetStat("Level")
            if level > 0 then
                levelDisplay.Text = "Level: " .. tostring(level)
            end
        end
    end)
    
    return {
    title = title,
    status = statusDisplay,
    toggle = toggle,
    levelDisplay = levelDisplay,
    debug = debugDisplay   
}
end

