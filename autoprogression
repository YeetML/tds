local function RunYeetEasy()
    if runningEasy then return end
    runningEasy = true
    getgenv().TimeScaleEnabled = false

    if not IsInLobby() then
        while true do
            -- 1. Check available maps
            local availableMaps = GetAvailableMaps()
            local availableStrategies = {}
            for _, strategy in ipairs(EasyStrategies) do
                if availableMaps[strategy.mapName] then
                    table.insert(availableStrategies, strategy)
                end
            end

            -- 2. If a map is found, load it
            if #availableStrategies > 0 then
                local chosen = availableStrategies[math.random(1, #availableStrategies)]
                ApplyStrategySettings(chosen)
                task.wait(0.3)
                print("[AutoProgression] Selected Easy: " .. chosen.name .. " on " .. chosen.mapName)
                loadstring(game:HttpGet(chosen.url))()
                runningEasy = false
                return
            end

            -- 3. No map – read the veto text
            local vetoInfo = GetVetoInfo()
            if not vetoInfo then
                print("[AutoProgression] Could not read veto text – assuming no vetoes.")
                break
            end

            -- 4. If used < total, we can veto again
            if vetoInfo.used < vetoInfo.total then
                print("[AutoProgression] Text: Veto (" .. vetoInfo.used .. "/" .. vetoInfo.total .. ") – vetoing.")
                VetoMap()
                -- Wait a moment, then loop again (in VIP, used stays 0, so we'll keep going)
            else
                print("[AutoProgression] Text: Veto (" .. vetoInfo.used .. "/" .. vetoInfo.total .. ") – no vetoes left.")
                break
            end
        end

        print("[AutoProgression] No Easy maps available. Teleporting to lobby...")
        SmartTeleportToLobby()
    else
        -- In lobby, just pick a random Easy strategy
        local chosen = EasyStrategies[math.random(1, #EasyStrategies)]
        ApplyStrategySettings(chosen)
        task.wait(0.3)
        print("[AutoProgression] In lobby, selected Easy: " .. chosen.name)
        loadstring(game:HttpGet(chosen.url))()
    end

    runningEasy = false
end

