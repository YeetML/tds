local function RunAutoProgression()
    if AutoProgressionRunning then return end
    AutoProgressionRunning = true
    task.wait(0.5)

    -- Check force toggles (mutual exclusivity already enforced in UI)
    local forceEasy = _G.AutoProgSettings.ForceEasy or false
    local forceFrost = _G.AutoProgSettings.ForceFrost or false
    local forceHcScout = _G.AutoProgSettings.ForceHardcoreScout or false
    local forceHcMinigunner = _G.AutoProgSettings.ForceHardcoreMinigunner or false
    local forceHcOperator = _G.AutoProgSettings.ForceHardcoreOperator or false
    local forceHcJuggernaut = _G.AutoProgSettings.ForceHardcoreJuggernaut or false

    -- If any force is ON, run that directly (skip level checks)
    if forceEasy then
        RunYeetEasy()
        AutoProgressionRunning = false
        return
    elseif forceFrost then
        local haveRocketeer = OwnsTower("Rocketeer")
        local haveGatling = OwnsTower("Gatling Gun")
        local haveTrapper = OwnsTower("Trapper")
        local haveHacker = OwnsTower("Hacker")
        if haveGatling and haveTrapper and haveHacker and haveRocketeer then
            RunFrostStrategy()
        else
