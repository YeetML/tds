-- ==================== PARTICLE SYSTEM ====================
local ParticleManager = {}
ParticleManager.__index = ParticleManager

function ParticleManager.new(parent)
    local self = setmetatable({}, ParticleManager)
    self.container = Instance.new("Folder")
    self.container.Name = "AetherParticles"
    self.container.Parent = parent
    self.particles = {}
    self.connections = {}
    return self
end

function ParticleManager:clear()
    for _, p in ipairs(self.particles) do p:Destroy() end
    for _, c in ipairs(self.connections) do c:Disconnect() end
    self.particles = {}
    self.connections = {}
end

function ParticleManager:startParticles(cfg)
    self:clear()
    if not cfg or cfg.type == "none" then return end

    local count = cfg.count or 25
    local speed = cfg.speed or 0.6
    local id = "rbxassetid://" .. cfg.id

    local screen = workspace.CurrentCamera.ViewportSize

    for i = 1, count do
        local img = Instance.new("ImageLabel")
        img.Image = id
        img.BackgroundTransparency = 1
        img.Size = UDim2.new(0, math.random(18, 34), 0, math.random(18, 34))
        img.Position = UDim2.new(0, math.random(0, screen.X), 0, math.random(-50, screen.Y))
        img.ImageTransparency = 0.35
        img.Parent = self.container
        table.insert(self.particles, img)

        local conn = game:GetService("RunService").Heartbeat:Connect(function(dt)
            local pos = img.Position
            img.Position = UDim2.new(0, pos.X.Offset + (math.random() - 0.5) * speed * 25,
                                     0, pos.Y.Offset + speed * 40 * dt * 30)
            img.Rotation = (img.Rotation or 0) + (math.random() - 0.5) * 4
            if img.Position.Y.Offset > screen.Y + 100 then
                img.Position = UDim2.new(0, math.random(0, screen.X), 0, -50)
            end
        end)
        table.insert(self.connections, conn)
    end
end

