-- ===== NEW: Smart teleport to lobby =====
local function SmartTeleportToLobby()
    local IsMobile = (game:GetService("UserInputService"):GetPlatform() == Enum.Platform.IOS or 
                      game:GetService("UserInputService"):GetPlatform() == Enum.Platform.Android)
    pcall(function()
        if not IsMobile and getgenv().PrivateCode and getgenv().PrivateCode ~= "" then
            game:GetService("ExperienceService"):LaunchExperience({
                placeId = LOBBY_ID,
                linkCode = getgenv().PrivateCode
            })
        else
            TeleportService:Teleport(LOBBY_ID)
        end
    end)
end

